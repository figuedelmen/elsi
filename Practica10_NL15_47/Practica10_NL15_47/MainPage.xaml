<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Practica10_NL15_47.MainPage">

    <Border StrokeShape="RoundRectangle 30"
            Margin="10"
            Padding="10"
            VerticalOptions="Center"
            HorizontalOptions="Center"
            WidthRequest="300"
            HeightRequest="300">
        <Border.Shadow>
            <Shadow Brush="Black"
                    Offset="10,10"
                    Radius="15"
                    Opacity="0.5"/>
        </Border.Shadow>

        <VerticalStackLayout Spacing="20">

            <Grid>
                <Entry BackgroundColor="Transparent"
                   TextColor="White"
                   Placeholder="UrlWeb"
                   x:Name="TexUrl"
                   HeightRequest="40"/>
            </Grid>

            <Button x:Name="BtnVer"
                    Text="Ver"
                    TextColor="White"
                    BackgroundColor="Transparent"
                    BorderColor="White"
                    BorderWidth="1"
                    Clicked="BtnVer_Clicked"/>

        </VerticalStackLayout>
       
    </Border>

</ContentPage>
