<?xml version="1.0" encoding="utf-8" ?> <!-- Indica que el archivo es XML versión 1.0 y usa codificación UTF-8 -->

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui" <!-- Define el espacio de nombres principal de .NET MAUI -->
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" <!-- Espacio de nombres XAML para usar propiedades como x:Name o x:Class -->
             x:Class="Proyecto1_NL15_47.segundaVentana" <!-- Especifica la clase en C# que está vinculada a esta vista -->
             Shell.NavBarIsVisible="False"> <!-- Oculta la barra superior de navegación del Shell -->

    <Grid BackgroundColor="White" <!-- Establece el color de fondo del Grid -->
          RowDefinitions="Auto, 1*" <!-- Define dos filas: la primera se ajusta automáticamente, la segunda ocupa el resto del espacio -->
          VerticalOptions="Fill" <!-- Hace que el Grid ocupe todo el alto disponible -->
          Margin="0" <!-- Elimina cualquier margen externo -->
          Padding="0" <!-- Elimina espacio interno dentro del Grid -->
          HorizontalOptions="Fill"> <!-- Hace que el Grid ocupe todo el ancho -->

        <HorizontalStackLayout Grid.Row="0" <!-- Indica que este layout está en la fila 0 del Grid -->
                               HorizontalOptions="Center" <!-- Centra los elementos horizontalmente -->
                               VerticalOptions="Center"> <!-- Centra los elementos verticalmente -->

            <Label Text="Inicio" <!-- Texto que se mostrará en pantalla -->
                   TextColor="Black" <!-- Color del texto -->
                   FontAttributes="Bold" <!-- Aplica estilo en negrita -->
                   FontSize="25"/> <!-- Tamaño de la fuente -->

        </HorizontalStackLayout>

        <Border StrokeThickness="0" <!-- Define que el borde no tendrá grosor visible -->
                StrokeShape="RoundRectangle 15" <!-- Define una forma rectangular con esquinas redondeadas de radio 15 -->
                Stroke="Black" <!-- Color del borde (aunque no se ve porque StrokeThickness=0) -->
                Grid.Row="1"> <!-- Ubica este elemento en la fila 1 del Grid -->

            <Border.Shadow> <!-- Define una sombra para el borde -->
                <Shadow Brush="Black" <!-- Color de la sombra -->
                        Offset="5,5" <!-- Desplazamiento de la sombra en X y Y -->
                        Radius="15" <!-- Nivel de difuminado de la sombra -->
                        Opacity="0.4"/> <!-- Nivel de transparencia de la sombra -->
            </Border.Shadow>

            <Grid RowDefinitions="1*,70"> <!-- Define dos filas internas: una flexible y otra fija de 70 -->

                <CollectionView ItemsSource="{Binding ListaAhorro}" <!-- Vincula la lista a una colección en el ViewModel -->
                                x:Name="ListAhorro" <!-- Nombre del control para acceder desde C# -->
                                Grid.Row="0" <!-- Ubicación en la fila 0 -->
                                SelectionMode="Single" <!-- Permite seleccionar un solo elemento -->
                                SelectionChanged="ListAhorro_SelectionChanged"> <!-- Evento cuando cambia la selección -->

                    <CollectionView.ItemTemplate> <!-- Define cómo se verá cada elemento de la lista -->
                        <DataTemplate> <!-- Plantilla de datos -->
                            <Grid> <!-- Contenedor del item -->

                                <Border StrokeShape="RoundRectangle 30" <!-- Bordes redondeados -->
                                        BackgroundColor="White" <!-- Fondo blanco -->
                                        Padding="10" <!-- Espacio interno -->
                                        Margin="10" <!-- Espacio externo entre elementos -->
                                        HeightRequest="100" <!-- Altura fija -->
                                        StrokeThickness="0"> <!-- Sin borde visible -->

                                    <Border.Shadow>
                                        <Shadow Brush="black" <!-- Color de sombra -->
                                                Offset="3,3" <!-- Desplazamiento -->
                                                Radius="10" <!-- Difuminado -->
                                                Opacity="0.5"/> <!-- Transparencia -->
                                    </Border.Shadow>

                                    <Grid ColumnDefinitions="100, 1*, 100"> <!-- Define tres columnas: fija, flexible y fija -->

                                        <Image Source="{Binding logo}" <!-- Imagen vinculada a la propiedad logo -->
                                               Grid.Column="0" <!-- Columna 0 -->
                                               Margin="10"/> <!-- Espacio alrededor -->

                                        <VerticalStackLayout Spacing="10" <!-- Espacio entre elementos internos -->
                                                             VerticalOptions="Center" <!-- Centra verticalmente -->
                                                             HorizontalOptions="Center" <!-- Centra horizontalmente -->
                                                             Grid.Column="1"> <!-- Ubicación en columna 1 -->

                                            <Label Text="{Binding nombre}" <!-- Muestra el nombre -->
                                                   FontAttributes="Bold" <!-- Negrita -->
                                                   TextColor="Black" <!-- Color -->
                                                   FontSize="20"/> <!-- Tamaño -->

                                            <Label Text="{Binding ahorrado, StringFormat='Ahorrado: {0}'}" <!-- Muestra cantidad formateada -->
                                                   FontAttributes="Bold"
                                                   TextColor="Black"
                                                   FontSize="20"/>

                                        </VerticalStackLayout>

                                        <Border StrokeShape="RoundRectangle 30" <!-- Bordes redondeados -->
                                                StrokeThickness="0" <!-- Sin borde -->
                                                Margin="10" <!-- Espacio externo -->
                                                Grid.Column="2" <!-- Columna 2 -->
                                                BackgroundColor="White"> <!-- Fondo -->

                                            <Border.Shadow>
                                                <Shadow Brush="Black"
                                                        Offset="2,2"
                                                        Radius="5"
                                                        Opacity="0.5"/>
                                            </Border.Shadow>

                                            <Button x:Name="BtnEliminar" <!-- Nombre del botón -->
                                                    Clicked="BtnEliminar_Clicked" <!-- Evento al hacer clic -->
                                                    BackgroundColor="White" <!-- Fondo -->
                                                    Text="🗑️" <!-- Icono -->
                                                    CommandParameter="{Binding .}"/> <!-- Pasa todo el objeto actual -->

                                        </Border>

                                    </Grid>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </CollectionView.ItemTemplate> 

                </CollectionView>

                <Border StrokeShape="RoundRectangle 30" <!-- Forma redondeada -->
                        BackgroundColor="White" <!-- Fondo -->
                        WidthRequest="60" <!-- Ancho fijo -->
                        Margin="5" <!-- Margen -->
                        StrokeThickness="0" <!-- Sin borde -->
                        HorizontalOptions="End" <!-- Alineado a la derecha -->
                        Grid.Row="1"> <!-- Ubicado en fila inferior -->

                    <Border.Shadow>
                        <Shadow Brush="Black"
                                Offset="3,3"
                                Radius="10"
                                Opacity="0.5"/>
                    </Border.Shadow>

                    <Button x:Name="BtnAgregar" <!-- Botón para agregar -->
                            BackgroundColor="White"
                            Text="+" <!-- Símbolo de agregar -->
                            BorderWidth="0" <!-- Sin borde -->
                            FontSize="20" <!-- Tamaño del texto -->
                            TextColor="Black" <!-- Color -->
                            Clicked="BtnAgregar_Clicked"/> <!-- Evento -->

                </Border>

            </Grid>

        </Border>

        <Grid x:Name="Poput" <!-- Contenedor tipo ventana emergente -->
              IsVisible="False" <!-- Oculto por defecto -->
              Grid.RowSpan="2"> <!-- Ocupa ambas filas del Grid principal -->

            <Border BackgroundColor="White" <!-- Fondo -->
                    StrokeShape="RoundRectangle 20" <!-- Bordes redondeados -->
                    StrokeThickness="0" <!-- Sin borde -->
                    Padding="5" <!-- Espacio interno -->
                    WidthRequest="280" <!-- Ancho -->
                    HorizontalOptions="Center" <!-- Centrado horizontal -->
                    VerticalOptions="Center"> <!-- Centrado vertical -->

                <Border.Shadow>
                    <Shadow Brush="Black"
                            Offset="2,2"
                            Radius="5"
                            Opacity="0.5"/>
                </Border.Shadow>

                <VerticalStackLayout Spacing="10"> <!-- Organización vertical -->

                    <Border StrokeShape="RoundRectangle 30"
                            StrokeThickness="0"
                            Margin="5"
                            BackgroundColor="White">

                        <Border.Shadow>
                            <Shadow Brush="Black"
                                    Offset="2,2"
                                    Radius="5"
                                    Opacity="0.5"/>
                        </Border.Shadow>

                        <Entry x:Name="txtNombre" <!-- Campo de texto -->
                               Placeholder="Nombre" <!-- Texto guía -->
                               Keyboard="Chat" <!-- Tipo de teclado -->
                               TextColor="Black"/> <!-- Color del texto -->

                    </Border>

                    <Border StrokeShape="RoundRectangle 30"
                            StrokeThickness="0"
                            Margin="5"
                            BackgroundColor="White">

                        <Border.Shadow>
                            <Shadow Brush="Black"
                                    Offset="2,2"
                                    Radius="5"
                                    Opacity="0.5"/>
                        </Border.Shadow>

                        <Picker x:Name="pickerLogos" <!-- Selector de opciones -->
                                Title="Selecciona un icono" <!-- Texto inicial -->
                                TitleColor="Gray" <!-- Color del título -->
                                TextColor="Black" <!-- Color del texto -->
                                Margin="10,0" <!-- Margen -->
                                HorizontalOptions="Fill"> <!-- Ocupa ancho -->

                            <Picker.ItemsSource> <!-- Lista interna -->
                                <x:Array Type="{x:Type x:String}"> <!-- Array de strings -->
                                    <x:String>Auto</x:String> <!-- Opción -->
                                    <x:String>Hogar</x:String>
                                    <x:String>Viaje</x:String>
                                    <x:String>Comida</x:String>
                                    <x:String>Regalo</x:String>
                                    <x:String>General</x:String>
                                </x:Array>
                            </Picker.ItemsSource>

                        </Picker>

                    </Border>

                    <HorizontalStackLayout HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Spacing="10"> <!-- Espacio entre botones -->

                        <Button Text="Guardar" <!-- Texto -->
                                x:Name="BtnGuardar" <!-- Nombre -->
                                BackgroundColor="Transparent"
                                TextColor="Black"
                                BorderColor="Black"
                                BorderWidth="1"
                                WidthRequest="90"
                                Clicked="BtnGuardar_Clicked"/> <!-- Evento -->

                        <Button Text="Cerrar"
                                x:Name="BtnCerrar"
                                BackgroundColor="Transparent"
                                TextColor="Black"
                                BorderColor="Black"
                                BorderWidth="1"
                                WidthRequest="90"
                                Clicked="BtnCerrar_Clicked"/>

                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Border>
        </Grid>

    </Grid>

</ContentPage>